---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionPreview from '../components/SectionPreview.astro';
import { t, getLocale, base } from '../i18n';
import { getVisibleSections } from '../lib/visibility';

const ui = t(getLocale());
const isDev = import.meta.env.DEV;

const allSectionKeys = ['phd', 'projects', 'cv', 'stack', 'labs', 'misc'] as const;
const sectionHrefs: Record<string, string> = {
  phd: base('/phd'), projects: base('/projects'), cv: base('/cv'),
  stack: base('/stack'), labs: base('/labs'), misc: base('/misc'),
};

const visibleSections = new Set(await getVisibleSections());

const sectionKeys = isDev
  ? allSectionKeys
  : allSectionKeys.filter((key) => visibleSections.has(key));

const sections = sectionKeys.map((key) => ({
  title: ui.sections[key].title,
  description: ui.sections[key].description,
  href: sectionHrefs[key],
}));
---

<BaseLayout title="Home" fullbleed>
  <Hero />

  <div class="container">
    <div class="sections-grid">
      {sections.map((s) => (
        <SectionPreview
          title={s.title}
          description={s.description}
          href={s.href}
        />
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .sections-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-sm);
    padding: var(--space-2xl) 0;
  }

  @media (max-width: 768px) {
    .sections-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
