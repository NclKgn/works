---
// src/components/Hero.astro
import motif from '../assets/skull-base-motif.svg';
import { getEntry } from 'astro:content';

const entry = await getEntry('hero', 'hero');
const { name, tagline, description } = entry!.data;
---

<section class="hero">
  <div class="hero-bg" aria-hidden="true">
    <img src={motif.src} alt="" class="hero-motif" />
  </div>

  <div class="container hero-content">
    <h1 class="hero-name">{name}</h1>
    <p class="hero-tagline small-caps">{tagline}</p>
    <p class="hero-desc">{description}</p>
  </div>

  <div class="hero-scroll" aria-hidden="true">
    <svg width="20" height="10" viewBox="0 0 20 10" fill="none" stroke="currentColor" stroke-width="1.5">
      <polyline points="2,2 10,8 18,2" />
    </svg>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    display: flex;
    justify-content: flex-end;
    align-items: center;
    pointer-events: none;
  }

  .hero-motif {
    width: 55%;
    max-width: 600px;
    opacity: 0.3;
    transform: translateX(10%);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 600px;
  }

  .hero-name {
    font-size: 3rem;
    letter-spacing: -0.03em;
    margin-bottom: var(--space-md);
  }

  .hero-tagline {
    color: var(--c-accent);
    margin-bottom: var(--space-lg);
  }

  .hero-desc {
    font-size: 1.05rem;
    color: var(--c-text-2);
    line-height: 1.7;
  }

  .hero-scroll {
    position: absolute;
    bottom: var(--space-lg);
    left: 50%;
    transform: translateX(-50%);
    color: var(--c-text-3);
    animation: drift 2s ease-in-out infinite;
  }

  @keyframes drift {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(6px); }
  }

  @media (max-width: 768px) {
    .hero-name { font-size: 2.2rem; }
    .hero-motif { width: 80%; opacity: 0.04; }
  }
</style>
