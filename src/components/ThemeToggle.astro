---
// src/components/ThemeToggle.astro
// Theme toggle button: system → light → dark → system
---

<button class="theme-toggle" id="theme-toggle" type="button" aria-label="Toggle theme">
  <svg class="icon-sun" aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="12" cy="12" r="5"></circle>
    <line x1="12" y1="1" x2="12" y2="3"></line>
    <line x1="12" y1="21" x2="12" y2="23"></line>
    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
    <line x1="1" y1="12" x2="3" y2="12"></line>
    <line x1="21" y1="12" x2="23" y2="12"></line>
    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
  </svg>
  <svg class="icon-moon" aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
  </svg>
</button>

<style>
  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    border-radius: var(--radius-sm);
    color: var(--c-text-2);
    transition: color 0.15s, background 0.15s;
    margin-left: 8px;
  }

  .theme-toggle:hover {
    color: var(--c-text);
    background: var(--c-border-light);
  }

  .theme-toggle:focus-visible {
    outline: 2px solid var(--c-accent);
    outline-offset: 2px;
  }

  /* Show moon in light mode, sun in dark mode */
  .icon-sun { display: none; }
  .icon-moon { display: block; }

  [data-theme="dark"] .icon-sun { display: block; }
  [data-theme="dark"] .icon-moon { display: none; }

  /* CSS-only fallback for OS dark preference */
  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) .icon-sun { display: block; }
    :root:not([data-theme="light"]) .icon-moon { display: none; }
  }
</style>

<script>
  const btn = document.getElementById('theme-toggle');
  const states = ['system', 'light', 'dark'] as const;

  function getState(): typeof states[number] {
    try {
      const saved = localStorage.getItem('theme');
      if (saved === 'light' || saved === 'dark') return saved;
    } catch (e) {}
    return 'system';
  }

  function apply(state: typeof states[number]) {
    if (state === 'system') {
      try { localStorage.removeItem('theme'); } catch (e) {}
      delete document.documentElement.dataset.theme;
      if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
        document.documentElement.dataset.theme = 'dark';
      }
    } else {
      try { localStorage.setItem('theme', state); } catch (e) {}
      document.documentElement.dataset.theme = state;
    }
    updateLabel(state);
  }

  function updateLabel(state: typeof states[number]) {
    const labels = { system: 'Switch to light theme', light: 'Switch to dark theme', dark: 'Switch to system theme' };
    btn?.setAttribute('aria-label', labels[state]);
  }

  btn?.addEventListener('click', () => {
    const current = getState();
    const next = states[(states.indexOf(current) + 1) % states.length];
    apply(next);
  });

  window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
    if (getState() === 'system') {
      if (e.matches) {
        document.documentElement.dataset.theme = 'dark';
      } else {
        delete document.documentElement.dataset.theme;
      }
    }
  });

  updateLabel(getState());
</script>
