---
// src/layouts/BaseLayout.astro
import Nav from '../components/Nav.astro';
import '../styles/global.css';
import { t, getLocale, base } from '../i18n';

interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
  fullbleed?: boolean;
}

const locale = getLocale();
const ui = t(locale);
const {
  title,
  description = 'Nicolas Kogane — Surgeon · Scientist · Engineer',
  noindex = false,
  fullbleed = false,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <script is:inline>
    (function() {
      try {
        var saved = localStorage.getItem('theme');
        if (saved === 'dark' || saved === 'light') {
          document.documentElement.dataset.theme = saved;
        } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          document.documentElement.dataset.theme = 'dark';
        }
      } catch (e) {}
    })();
  </script>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — Nicolas Kogane</title>
  <meta name="description" content={description} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}
  <link rel="sitemap" href={base('/sitemap-index.xml')} />
  <link rel="alternate" type="application/rss+xml" title="PhD Newsletter" href={base('/rss.xml')} />
</head>
<body>
  <Nav />

  <main style={fullbleed ? undefined : 'padding-top: var(--nav-h);'}>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="container footer-inner">
      <span>{ui.footer.name}</span>
      <span class="footer-sep">&middot;</span>
      <span>{ui.footer.tagline}</span>
    </div>
  </footer>

  <style>
    .site-footer {
      border-top: 1px solid var(--c-border);
      margin-top: var(--space-2xl);
    }

    .footer-inner {
      padding: var(--space-lg) 0;
      text-align: center;
      font-size: 0.78rem;
      color: var(--c-text-3);
    }

    .footer-sep {
      margin: 0 6px;
    }
  </style>
</body>
</html>
